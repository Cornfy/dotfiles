{
    "layer": "bottom",
    "position": "bottom", // Waybar position (top|bottom|left|right)
    "height": 30,
    "modules-left": ["custom/launcher", "tray"],
    "modules-right": ["idle_inhibitor", "temperature", "cpu", "memory", "network", "custom/network_traffic", "backlight", "pulseaudio", "clock", "battery" , "custom/power"],

 // Modules configuration

    "custom/launcher": {
    	"format":"п„µ ",
    	"on-click": "rofi -show-icons -show drun",
    	"tooltip": false,
    },

    "tray": {
        "icon-size": 14,
        "spacing": 5
    },

    "idle_inhibitor": {
        "format": "{icon}",
       "format-icons": {
            "activated": "пЃ® ",
            "deactivated": "пЃ° "
        }
    },

    "temperature": {
        "critical-threshold": 80,
        "format": "п‹‰ {temperatureC}В°C"
    },

    "cpu": {
        "format": "п’ј  {usage: >3}%",
        "on-click": "alacritty -e htop"
    },

    "memory": {
        "format": "пѓ‰  {: >3}%",
        "on-click": "alacritty -e htop"
    },

    "network": {
        "format": "вљ    Disabled",
        "format-wifi": "п‡«   {essid}",
        "format-ethernet": "пѓЃ   {ifname}: {ipaddr}/{cidr}",
        "format-disconnected": "вљ    Disconnected",
        "on-click": "alacritty -e nmtui"
    },

    "custom/network_traffic": {
             "exec": "~/.config/waybar/scripts/network_traffic.sh",
             "return-type": "json",
             "format-ethernet": "{icon} {ifname} в‡Ј{bandwidthDownBytes:>4} в‡Ў{bandwidthUpBytes:>4}",
    },

    "backlight": {
        "format": "{icon} {percent: >3}%",
        "format-icons": ["п†…  ", "п„‘  "],
        "on-scroll-down": "brightnessctl -c backlight set 5%-",
        "on-scroll-up": "brightnessctl -c backlight set +5%"
    },

    "pulseaudio": {
        "scroll-step": 5,
        "format": "{icon} {volume: >3}%",
        "format-bluetooth": "{icon} {volume: >3}%",
        "format-muted":"пЂ¦ muted",
        "format-icons": {
            "headphones": "пЂҐ ",
            "handsfree": "пЂҐ ",
            "headset": "пЂҐ ",
            "phone": "п‚• ",
            "portable": "п‚• ",
            "car": "п†№ ",
            "default": ["пЂ§  ", "пЂЁ  "]
        },
        "on-click": "pavucontrol"
    },

    "clock": {
        "format": "п„і  {:%Y-%m-%d, %a  пЂ—  %H:%M:%S}",	//24 hour format
        "format-alt": "п„і  {:%Y-%m-%d, %a  пЂ—  %I:%M:%S %p}",	//12 hour format
        "interval": 1
    },

    "battery": {
        "states": {
            "good": 95,
            "warning": 30,
            "critical": 15
        },
        "format": "{icon} {capacity: >3}%",
        "format-icons": ["п‰„  ", "п‰ѓ  ", "п‰‚  ", "п‰Ѓ  ", "п‰Ђ  "]
    },

    "custom/power": {
      	"format":"вЏ» ",
       	"on-click": "wlogout",
      	"tooltip": false,
    },

}
